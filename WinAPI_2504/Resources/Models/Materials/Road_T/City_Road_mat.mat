<Material Name="City_Road_mat">
    <Shader Vertex="Light/Light.hlsl" Pixel="Light/Light.hlsl"/>
    <Texture>
        <DiffuseMap Diffuse="Resources\Textures\Model\LowPolyAssets\Road Concrete Tile.png"/>
        <SpecularMap Specular="Resources/Textures/Color/White.png"/>
        <NormalMap Normal="Resources\Textures\Model\LowPolyAssets\Tiles_2_Normal.png"/>
    </Texture>
    <Property Shininess="20" HasNormalMap="1">
        <Diffuse R="1" G="1" B="1" A="1"/>
        <Specular R="1" G="1" B="1" A="1"/>
        <Ambient R="0" G="0" B="0" A="1"/>
        <Emissive R="0" G="0" B="0" A="1"/>
    </Property>
</Material>
