<Material Name="Roads">
    <Shader Vertex="Light/Light.hlsl" Pixel="Light/Light.hlsl"/>
    <Texture>
        <DiffuseMap Diffuse="Resources/Textures/Color/White.png"/>
        <SpecularMap Specular="Resources/Textures/Color/White.png"/>
        <NormalMap Normal="Resources/Textures/Color/White.png"/>
    </Texture>
    <Property Shininess="0.75" HasNormalMap="0">
        <Diffuse R="0.80000001" G="0.80000001" B="0.80000001" A="1"/>
        <Specular R="1" G="1" B="1" A="1"/>
        <Ambient R="0.2" G="0.2" B="0.2" A="1"/>
        <Emissive R="0" G="0" B="0" A="1"/>
    </Property>
</Material>
